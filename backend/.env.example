NODE_ENV=development
PORT=3000

# MySQL — adjust to your local setup
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gym_db

# JWT — must be at least 32 characters; change before deploying
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1d
JWT_ISSUER=gym-api
